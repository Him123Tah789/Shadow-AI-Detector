# ══════════════════════════════════════════════════
#  ShieldOps — Environment Variables
# ══════════════════════════════════════════════════

# ── Database ──────────────────────────────────────
POSTGRES_USER=shadow_user
POSTGRES_PASSWORD=shadow_password
POSTGRES_DB=shadow_db

# ── Backend Security ──────────────────────────────
SECRET_KEY=supersecretkey_change_in_production

# ── Module B: Email Encryption ────────────────────
# Generate: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# ── Module B: Breach Data Source ──────────────────
# Options: "mock" (default, fake data) or "hibp" (real, needs API key)
BREACH_CHECKER=mock
HIBP_API_KEY=

# ── Notifications ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@shieldops.app

# ── Telegram (v1.1) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
